# Copy to .streamlit/secrets.toml for local dev, and paste the same into
# Streamlit Community Cloud → App → Settings → Secrets for deployment.
# NOTE: in this Community-Cloud build the key is injected into the browser
# after login, so any logged-in Streamax user can read it. Use a key with
# usage limits / budget alerts.
ANTHROPIC_API_KEY = "sk-ant-..."
